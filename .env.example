# MySQL Connection Details
# Copy this file to .env (for local run) or .env.docker (for Docker run) and configure variables:
MYSQL_HOST=localhost            # Set to 'localhost' for local running, or 'host.docker.internal' for Docker
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=hospital_db

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
MODEL_VERSION=1.0.0
